# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenRouter API (for AI model access)
OPENROUTER_API_KEY=your_openrouter_key_here

# App URL (used for embed code generation)
NEXT_PUBLIC_APP_URL=https://mj-talk.vercel.app


# Support / contact email shown on the "Contact Support" button and in legal pages.
# Use a professional address (e.g. support@yourdomain.com) — avoid personal Gmail addresses.
# Fallback in code: support@mjtalk.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@mjtalk.com

# Platform super-admin email — this user gets access to Purchase Requests and
# all platform-level admin features. Change this to your own email.
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=meerujutti0.001@gmail.com

# AI Assistant Widget — shown on landing page + dashboard
# Set this to any active chatbot UUID from your dashboard
NEXT_PUBLIC_DEMO_CHATBOT_ID=

# Resend — for Contact Support emails (https://resend.com)
# Without this key, contact form submissions are logged server-side only
RESEND_API_KEY=

# ─── Stripe Billing ────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — from https://dashboard.stripe.com/webhooks
# Endpoint URL: https://mj-talk.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in Stripe Dashboard → Products
# Premium monthly: $29/mo recurring
STRIPE_PREMIUM_PRICE_ID=price_...
# Premium yearly: $290/yr recurring (optional — falls back to monthly price if not set)
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...
